# Local overrides — copy to config/local.yaml and edit for your machine.
# This file is intentionally conservative. Keep secrets in .env, not here.

database:
  url: "postgresql://fmo:fmo@localhost:5432/fmo"

storage:
  source_roots:
    - "/Users/me/Pictures"
    # - "/Volumes/Archive/Photos"
  derivative_cache_root: "/tmp/fmo_cache"

model:
  provider: "gemini"
  name: "gemini-3.1-flash-lite-preview"

deepinfra:
  base_url: "https://api.deepinfra.com/v1/openai"
  default_model: "meta-llama/Llama-3.2-11B-Vision-Instruct"

lmstudio:
  base_url: "http://127.0.0.1:1234/v1"
  default_model: "google/gemma-3-27b"

worker:
  concurrency: 2
  image_analysis_max_px: 1200
  ai_max_output_tokens: null
  batch_chunk_size: 100
  batch_max_concurrent: 100
  # Set a number only if you explicitly want to cap model output.
