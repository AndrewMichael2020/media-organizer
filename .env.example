# Copy to .env for local development.
# Keep secrets here, not in config/local.yaml.

# === API ===
FMO_DATABASE_URL=postgresql://fmo:fmo@localhost:5432/fmo
FMO_CORS_ORIGINS=["http://localhost:3000"]

# === Model ===
FMO_MODEL_PROVIDER=gemini
FMO_MODEL_NAME=gemini-2.0-flash-lite
GEMINI_API_KEY=your_gemini_api_key_here

# === Storage ===
# FMO_SOURCE_ROOTS=["/path/to/photos", "/path/to/more"]
# FMO_DERIVATIVE_CACHE_ROOT=/tmp/fmo_cache

# === Worker (optional overrides) ===
# FMO_WORKER_CONCURRENCY=2
# FMO_WORKER_IMAGE_ANALYSIS_MAX_PX=1200
# FMO_WORKER_AI_MAX_OUTPUT_TOKENS=
